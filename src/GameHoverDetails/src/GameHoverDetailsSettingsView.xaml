<UserControl x:Class="GameHoverDetails.GameHoverDetailsSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="760"
             DataContextChanged="UserControl_DataContextChanged"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    <UserControl.Resources>
        <FontFamily x:Key="HoverFieldIconFont">Segoe MDL2 Assets</FontFamily>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="HoverPreviewFieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Foreground" Value="#98989D" />
            <Setter Property="LineHeight" Value="14" />
            <Setter Property="Typography.Capitals" Value="AllSmallCaps" />
        </Style>
        <!-- Playnite themes often give ItemsControl a ScrollViewer; override so the Fields list only scrolls on the outer RootScrollViewer. -->
        <Style x:Key="FieldsListNonScrollingItemsControlStyle" TargetType="ItemsControl">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ItemsControl">
                        <StackPanel IsItemsHost="True"
                                    Focusable="False"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="280" />
            <ColumnDefinition Width="238" />
        </Grid.ColumnDefinitions>

        <ScrollViewer x:Name="RootScrollViewer"
                      Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,8,0">
            <StackPanel Margin="16">
                <CheckBox Content="Enable hover details"
                          Foreground="{DynamicResource TextBrush}"
                          Margin="0,0,0,10"
                          IsChecked="{Binding HoverDetailsEnabled, Mode=TwoWay}" />

                <Label Content="Display:"
                       Margin="0,36,0,4"
                       Foreground="{DynamicResource TextBrush}" />
                <TextBlock Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           FontSize="11.5"
                           LineHeight="16"
                           Text="Row titles and catalog icons beside values (game-art and platform rows unchanged)." />
                <CheckBox Content="Show titles"
                          Foreground="{DynamicResource TextBrush}"
                          IsChecked="{Binding HoverTitlesInHover, Mode=TwoWay}" />
                <CheckBox Margin="0,12,0,0"
                          Content="Show icons"
                          Foreground="{DynamicResource TextBrush}"
                          IsChecked="{Binding ShowFieldInlineIconsInHover, Mode=TwoWay}" />

                <Label Margin="0,40,0,4"
                       Content="Timing &amp; size"
                       Foreground="{DynamicResource TextBrush}" />
                <TextBlock Margin="0,0,0,14"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           FontSize="11.5"
                           LineHeight="16"
                           Text="Open delay, panel width, and vertical gap between field blocks." />
                <Label Margin="0,0,0,4"
                       Content="Tooltip appear delay"
                       Foreground="{DynamicResource TextBrush}" />
                <Slider Minimum="0"
                        Maximum="500"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="{Binding ShowDelayMs, Mode=TwoWay}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextBrush}"
                           Text="{Binding ShowDelayMs, StringFormat='{}{0} ms'}" />

                <Label Margin="0,26,0,4"
                       Content="Hover panel width"
                       Foreground="{DynamicResource TextBrush}" />
                <Slider x:Name="WidthSlider"
                        Minimum="120"
                        Maximum="500"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="{Binding HoverWidth, Mode=TwoWay}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextBrush}"
                           Text="{Binding HoverWidth, StringFormat='{}{0} px'}" />

                <Label Margin="0,26,0,4"
                       Content="Space between field rows"
                       Foreground="{DynamicResource TextBrush}" />
                <Slider Minimum="4"
                        Maximum="36"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="{Binding HoverFieldBlockSpacingDip, Mode=TwoWay}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextBrush}"
                           Text="{Binding HoverFieldBlockSpacingDip, StringFormat='{}{0} px'}" />

                <Label Margin="0,40,0,4"
                       Content="Fields"
                       Foreground="{DynamicResource TextBrush}" />
                <TextBlock Margin="0,0,0,12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           FontSize="11.5"
                           LineHeight="16"
                           Text="Tooltip order top→bottom; ↑↓ reorder, Remove row; Add field stays open for multiple picks." />

                <Border Padding="10,10,10,12"
                        HorizontalAlignment="Stretch"
                        BorderThickness="1"
                        CornerRadius="3"
                        BorderBrush="#5C5C64">
                    <StackPanel>
                        <Label Margin="0,0,0,4"
                               Content="Add a field"
                               Foreground="{DynamicResource TextBrush}" />
                        <ComboBox x:Name="AddFieldCombo"
                                  HorizontalContentAlignment="Left"
                                  HorizontalAlignment="Stretch"
                                  MinHeight="32"
                                  Margin="0,0,0,12"
                                  Foreground="{DynamicResource TextBrush}"
                                  DropDownClosed="AddFieldCombo_DropDownClosed"
                                  PreviewKeyDown="AddFieldCombo_PreviewKeyDown">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <EventSetter Event="PreviewMouseLeftButtonDown"
                                                 Handler="AddFieldComboItem_PreviewMouseLeftButtonDown" />
                                    <EventSetter Event="PreviewMouseLeftButtonUp"
                                                 Handler="AddFieldComboItem_PreviewMouseLeftButtonUp" />
                                </Style>
                            </ComboBox.ItemContainerStyle>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="26">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{StaticResource HoverFieldIconFont}"
                                                   FontSize="15"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Opacity="0.92"
                                                   Text="{Binding SettingsGlyph}" />
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <ItemsControl x:Name="FieldsList"
                                      Style="{StaticResource FieldsListNonScrollingItemsControlStyle}"
                                      Margin="0"
                                      Padding="0"
                                      HorizontalAlignment="Stretch"
                                      Foreground="{DynamicResource TextBrush}">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{StaticResource HoverFieldIconFont}"
                                                   FontSize="15"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Opacity="0.92"
                                                   Text="{Binding SettingsGlyph}" />
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Margin="8,0,0,0">
                                            <Button Padding="8,4"
                                                    MinWidth="30"
                                                    Content="↑"
                                                    FontSize="14"
                                                    ToolTip="Move up"
                                                    IsEnabled="{Binding CanMoveUp}"
                                                    Click="EnabledMoveUp_Click" />
                                            <Button Padding="8,4"
                                                    MinWidth="30"
                                                    Margin="6,0,0,0"
                                                    Content="↓"
                                                    FontSize="14"
                                                    ToolTip="Move down"
                                                    IsEnabled="{Binding CanMoveDown}"
                                                    Click="EnabledMoveDown_Click" />
                                            <Button Padding="8,4"
                                                    MinWidth="56"
                                                    Margin="6,0,0,0"
                                                    Content="Remove"
                                                    ToolTip="Remove from hover"
                                                    Click="EnabledRemove_Click" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Live preview: Display + Timing & size (width, spacing, titles, icons, enable) -->
        <StackPanel Grid.Column="1"
                    Margin="6,16,8,16"
                    VerticalAlignment="Top"
                    ClipToBounds="False">
            <TextBlock Text="Preview"
                       Foreground="{DynamicResource TextBrush}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <Border HorizontalAlignment="Left"
                    MinWidth="120"
                    MaxWidth="216"
                    Width="{Binding HoverWidth}"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#48484E"
                    Background="#1C1C1E"
                    Padding="14,12"
                    Margin="0,0,4,0"
                    UseLayoutRounding="True"
                    SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14"
                                      ShadowDepth="2"
                                      Opacity="0.32"
                                      Direction="270"
                                      Color="Black" />
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HoverDetailsEnabled}" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ItemsControl x:Name="PreviewFieldsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent"
                                    Margin="{Binding ContentBlockMargin}">
                                <StackPanel>
                                    <Border Height="1"
                                            Margin="{Binding SeparatorMargin}"
                                            Background="#3C3C40"
                                            Visibility="{Binding ShowTopSeparator, Converter={StaticResource BoolToVis}}" />

                                    <!-- Game art (stacked); hidden when Icon is the only field — hover uses name beside icon. -->
                                    <StackPanel Margin="{Binding ContinuationRowOutermostMargin}"
                                                Visibility="{Binding ShowArtVerticalStack, Converter={StaticResource BoolToVis}}">
                                        <Image Stretch="Uniform"
                                               HorizontalAlignment="Left"
                                               MaxWidth="{Binding PreviewArtMaxWidth}"
                                               MaxHeight="{Binding PreviewArtMaxHeight}"
                                               Source="{Binding PreviewArt}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="13"
                                                   Foreground="#E6E6E6"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   LineHeight="18"
                                                   MaxHeight="54"
                                                   ClipToBounds="True"
                                                   Text="{Binding SampleValue}"
                                                   Visibility="{Binding ShowSampleText, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>

                                    <!-- Icon-only + art: game name beside icon (matches hover vertical alignment). -->
                                    <Grid Margin="{Binding ContinuationRowOutermostMargin}"
                                          Visibility="{Binding ShowIconBesideGameNameRow, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0"
                                               Width="40"
                                               Height="40"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               Stretch="Uniform"
                                               MaxWidth="{Binding PreviewArtMaxWidth}"
                                               MaxHeight="{Binding PreviewArtMaxHeight}"
                                               Source="{Binding PreviewArt}" />
                                        <TextBlock Grid.Column="1"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   Foreground="#E6E6E6"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   LineHeight="18"
                                                   MaxHeight="54"
                                                   MaxWidth="{Binding BesideIconNameMaxWidth}"
                                                   ClipToBounds="True"
                                                   Text="{Binding BesideIconGameName}" />
                                    </Grid>

                                    <!-- Title + icon + value (stat row) -->
                                    <Grid Margin="{Binding ContinuationRowOutermostMargin}"
                                          Visibility="{Binding ShowStatRowLayout, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="32"
                                                Height="32"
                                                CornerRadius="16"
                                                Background="#3A3A3E"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <TextBlock FontFamily="{StaticResource HoverFieldIconFont}"
                                                       FontSize="15"
                                                       Foreground="#D2D2D8"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding GlyphText}" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Margin="10,0,0,0">
                                            <TextBlock Margin="0,0,0,4"
                                                       Style="{StaticResource HoverPreviewFieldLabel}"
                                                       MaxWidth="{Binding StatTextMaxWidth}"
                                                       Text="{Binding DisplayName}" />
                                            <TextBlock FontSize="13"
                                                       Foreground="#E6E6E6"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       LineHeight="18"
                                                       MaxHeight="54"
                                                       MaxWidth="{Binding StatTextMaxWidth}"
                                                       ClipToBounds="True"
                                                       Text="{Binding SampleValue}"
                                                       Visibility="{Binding ShowSampleText, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Title + value (no icon) -->
                                    <StackPanel Visibility="{Binding ShowTitleBodyNoIconLayout, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Margin="{Binding PreviewFieldTitleMargin}"
                                                   Style="{StaticResource HoverPreviewFieldLabel}"
                                                   Text="{Binding DisplayName}" />
                                        <TextBlock FontSize="13"
                                                   Foreground="#E6E6E6"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   LineHeight="18"
                                                   MaxHeight="54"
                                                   ClipToBounds="True"
                                                   Text="{Binding SampleValue}"
                                                   Visibility="{Binding ShowSampleText, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>

                                    <!-- Icon chip + value (no title) -->
                                    <Grid Margin="{Binding ContinuationRowOutermostMargin}"
                                          Visibility="{Binding ShowChipValueNoTitleLayout, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="32"
                                                Height="32"
                                                CornerRadius="16"
                                                Background="#3A3A3E"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <TextBlock FontFamily="{StaticResource HoverFieldIconFont}"
                                                       FontSize="15"
                                                       Foreground="#D2D2D8"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding GlyphText}" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   Foreground="#E6E6E6"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   LineHeight="18"
                                                   MaxHeight="54"
                                                   MaxWidth="{Binding StatTextMaxWidth}"
                                                   ClipToBounds="True"
                                                   Text="{Binding SampleValue}"
                                                   Visibility="{Binding ShowSampleText, Converter={StaticResource BoolToVis}}" />
                                    </Grid>

                                    <!-- Value only -->
                                    <TextBlock Margin="{Binding ContinuationRowOutermostMargin}"
                                               FontSize="13"
                                               Foreground="#E6E6E6"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               LineHeight="18"
                                               MaxHeight="54"
                                               ClipToBounds="True"
                                               Text="{Binding SampleValue}"
                                               Visibility="{Binding ShowValueOnlyLayout, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
