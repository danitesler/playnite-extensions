<UserControl x:Class="GameHoverDetails.GameHoverDetailsSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="760"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    <UserControl.Resources>
        <FontFamily x:Key="HoverFieldIconFont">Segoe MDL2 Assets</FontFamily>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="280" />
            <ColumnDefinition Width="238" />
        </Grid.ColumnDefinitions>

        <ScrollViewer x:Name="RootScrollViewer"
                      Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,8,0">
            <StackPanel Margin="16">
                <CheckBox Content="Enable hover details"
                          Foreground="{DynamicResource TextBrush}"
                          Margin="0,0,0,10"
                          IsChecked="{Binding HoverDetailsEnabled, Mode=TwoWay}" />

                <Label Content="Display:"
                       Margin="0,36,0,4"
                       Foreground="{DynamicResource TextBrush}" />
                <TextBlock Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           FontSize="11.5"
                           LineHeight="16"
                           Text="Choose whether text rows show the field name (for example Publisher) and a small catalog icon beside the value. Cover, background, small tile art, and platform logo strips are not affected." />
                <CheckBox Content="Show titles"
                          Foreground="{DynamicResource TextBrush}"
                          IsChecked="{Binding HoverTitlesInHover, Mode=TwoWay}" />
                <CheckBox Margin="0,12,0,0"
                          Content="Show icons"
                          Foreground="{DynamicResource TextBrush}"
                          IsChecked="{Binding ShowFieldInlineIconsInHover, Mode=TwoWay}" />

                <Label Margin="0,40,0,4"
                       Content="Timing &amp; size"
                       Foreground="{DynamicResource TextBrush}" />
                <TextBlock Margin="0,0,0,14"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           FontSize="11.5"
                           LineHeight="16"
                           Text="How long the pointer rests on a game before the hover opens, how wide the panel is, and how much vertical space sits between each field block in the hover." />
                <Label Margin="0,0,0,4"
                       Content="Tooltip appear delay"
                       Foreground="{DynamicResource TextBrush}" />
                <Slider Minimum="0"
                        Maximum="500"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="{Binding ShowDelayMs, Mode=TwoWay}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextBrush}"
                           Text="{Binding ShowDelayMs, StringFormat='{}{0} ms'}" />

                <Label Margin="0,26,0,4"
                       Content="Hover panel width"
                       Foreground="{DynamicResource TextBrush}" />
                <Slider x:Name="WidthSlider"
                        Minimum="120"
                        Maximum="500"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="{Binding HoverWidth, Mode=TwoWay}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextBrush}"
                           Text="{Binding HoverWidth, StringFormat='{}{0} px'}" />

                <Label Margin="0,26,0,4"
                       Content="Space between field rows"
                       Foreground="{DynamicResource TextBrush}" />
                <Slider Minimum="4"
                        Maximum="36"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="{Binding HoverFieldBlockSpacingDip, Mode=TwoWay}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextBrush}"
                           Text="{Binding HoverFieldBlockSpacingDip, StringFormat='{}{0} px'}" />

                <Label Margin="0,40,0,4"
                       Content="Fields"
                       Foreground="{DynamicResource TextBrush}" />
                <TextBlock Margin="0,0,0,12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           FontSize="11.5"
                           LineHeight="16"
                           Text="Top to bottom in the tooltip. ↑ / ↓ reorder, Remove removes a row, then choose a field below to add." />

                <Border Padding="10,10,10,12"
                        HorizontalAlignment="Stretch"
                        BorderThickness="1"
                        CornerRadius="3"
                        BorderBrush="#5C5C64">
                    <StackPanel>
                        <ListBox x:Name="FieldsList"
                                 MinHeight="120"
                                 MaxHeight="240"
                                 Padding="0"
                                 Margin="0"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Stretch"
                                 SelectionMode="Single"
                                 Foreground="{DynamicResource TextBrush}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingStackPanel.IsVirtualizing="False">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="2,4,4,4" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{StaticResource HoverFieldIconFont}"
                                                   FontSize="15"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Opacity="0.92"
                                                   Text="{Binding SettingsGlyph}" />
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Margin="8,0,0,0">
                                            <Button Padding="8,4"
                                                    MinWidth="30"
                                                    Content="↑"
                                                    FontSize="14"
                                                    ToolTip="Move up"
                                                    IsEnabled="{Binding CanMoveUp}"
                                                    Click="EnabledMoveUp_Click" />
                                            <Button Padding="8,4"
                                                    MinWidth="30"
                                                    Margin="6,0,0,0"
                                                    Content="↓"
                                                    FontSize="14"
                                                    ToolTip="Move down"
                                                    IsEnabled="{Binding CanMoveDown}"
                                                    Click="EnabledMoveDown_Click" />
                                            <Button Padding="8,4"
                                                    MinWidth="56"
                                                    Margin="6,0,0,0"
                                                    Content="Remove"
                                                    ToolTip="Remove from hover"
                                                    Click="EnabledRemove_Click" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Label Margin="0,14,0,4"
                               Content="Add a field"
                               Foreground="{DynamicResource TextBrush}" />
                        <ComboBox x:Name="AddFieldCombo"
                                  HorizontalContentAlignment="Left"
                                  HorizontalAlignment="Stretch"
                                  MinHeight="32"
                                  Foreground="{DynamicResource TextBrush}"
                                  SelectionChanged="AddFieldCombo_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="26">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{StaticResource HoverFieldIconFont}"
                                                   FontSize="15"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Opacity="0.92"
                                                   Text="{Binding SettingsGlyph}" />
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Live preview: Display + Timing & size (width, delay, spacing, titles, icons, enable) -->
        <StackPanel Grid.Column="1"
                    Margin="8,16,16,16"
                    VerticalAlignment="Top">
            <TextBlock Text="Preview"
                       Foreground="{DynamicResource TextBrush}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />
            <TextBlock Margin="0,0,0,10"
                       Foreground="{DynamicResource TextBrush}"
                       Opacity="0.8"
                       FontSize="11"
                       Text="{Binding ShowDelayMs, StringFormat='Delay {0} ms'}" />

            <Border HorizontalAlignment="Left"
                    MinWidth="120"
                    MaxWidth="216"
                    Width="{Binding HoverWidth}"
                    CornerRadius="4"
                    BorderThickness="1"
                    BorderBrush="#646468"
                    Background="#1C1C1E"
                    Padding="12,10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HoverDetailsEnabled}" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ItemsControl x:Name="PreviewFieldsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="{Binding OuterMargin}"
                                    Background="Transparent">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               FontSize="12"
                                               Foreground="White"
                                               Margin="0,0,0,4"
                                               Text="{Binding DisplayName}"
                                               Visibility="{Binding DataContext.HoverTitlesInHover, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   FontFamily="{StaticResource HoverFieldIconFont}"
                                                   FontSize="14"
                                                   Foreground="#D2D2D8"
                                                   VerticalAlignment="Top"
                                                   Margin="0,1,6,0"
                                                   Text="{Binding GlyphText}"
                                                   Visibility="{Binding ShowInlineGlyph, Converter={StaticResource BoolToVis}}" />
                                        <StackPanel Grid.Column="{Binding ValueContentColumn}"
                                                    Grid.ColumnSpan="{Binding ValueContentColumnSpan}">
                                            <TextBlock FontSize="13"
                                                       Foreground="#E6E6E6"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       LineHeight="18"
                                                       MaxHeight="54"
                                                       ClipToBounds="True"
                                                       Text="{Binding SampleValue}"
                                                       Visibility="{Binding ShowSampleText, Converter={StaticResource BoolToVis}}" />
                                            <Image Stretch="Uniform"
                                                   HorizontalAlignment="Left"
                                                   MaxWidth="{Binding PreviewArtMaxWidth}"
                                                   MaxHeight="{Binding PreviewArtMaxHeight}"
                                                   Margin="0,2,0,0"
                                                   Source="{Binding PreviewArt}"
                                                   Visibility="{Binding ShowPreviewArt, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
