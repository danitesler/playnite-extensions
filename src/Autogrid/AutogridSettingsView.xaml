<UserControl x:Class="Autogrid.AutogridSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400">
    <StackPanel Margin="16">
        <CheckBox Content="Enable Autogrid (Desktop grid view only)"
                  IsChecked="{Binding Enabled, Mode=TwoWay}" />
        <Label Margin="0,16,0,4" Content="Target columns (horizontal tiles)" />
        <Slider Minimum="1"
                Maximum="20"
                Value="{Binding TargetColumns, Mode=TwoWay}"
                TickFrequency="1"
                IsSnapToTickEnabled="True" />
        <TextBlock Margin="0,4,0,0"
                   Foreground="{DynamicResource TextBrush}"
                   Text="{Binding TargetColumns, StringFormat=Columns: {0}}" />
        <Label Margin="0,16,0,4" Content="Viewport adjust (pixels)" />
        <Slider Minimum="-200"
                Maximum="200"
                Value="{Binding ViewportAdjustPx, Mode=TwoWay}"
                TickFrequency="1"
                IsSnapToTickEnabled="True" />
        <TextBlock Margin="0,4,0,0"
                   Foreground="{DynamicResource TextBrush}"
                   Text="{Binding ViewportAdjustPx, StringFormat='Adjust: {0} px; positive adds usable width'}" />
        <CheckBox Margin="0,12,0,0"
                  Content="Log debug measurements (rate-limited; check Playnite log)"
                  IsChecked="{Binding LogDebugMeasurements, Mode=TwoWay}" />
        <TextBlock Margin="0,20,0,0"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextBrush}"
                   Text="When you resize the Playnite window, grid cover width adjusts so about this many columns fit across the library area. Use viewport adjust if a theme still leaves side gutters. If a Playnite update stops this from working, open an issue with your Playnite version." />
    </StackPanel>
</UserControl>
