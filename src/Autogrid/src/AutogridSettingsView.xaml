<UserControl x:Class="Autogrid.AutogridSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Autogrid"
             mc:Ignorable="d"
             d:DesignHeight="420" d:DesignWidth="400">
    <UserControl.Resources>
        <local:GridSizingModeToBoolConverter x:Key="ColumnsModeConverter" TargetMode="Columns" />
        <local:GridSizingModeToBoolConverter x:Key="RowsModeConverter" TargetMode="Rows" />
    </UserControl.Resources>
    <StackPanel Margin="16">
        <CheckBox Content="Enable Autogrid (Desktop grid view only)"
                  IsChecked="{Binding Enabled, Mode=TwoWay}" />

        <Label Margin="0,16,0,4" Content="Sizing mode" />
        <StackPanel Orientation="Horizontal">
            <RadioButton Content="Columns"
                         Margin="0,0,16,0"
                         IsChecked="{Binding SizingMode, Converter={StaticResource ColumnsModeConverter}, Mode=TwoWay}" />
            <RadioButton Content="Rows"
                         IsChecked="{Binding SizingMode, Converter={StaticResource RowsModeConverter}, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Margin="0,12,0,0">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SizingMode}" Value="Rows">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <Label Margin="0,0,0,4" Content="Target columns (horizontal tiles)" />
            <Slider Minimum="1"
                    Maximum="20"
                    Value="{Binding TargetColumns, Mode=TwoWay}"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{DynamicResource TextBrush}"
                       Text="{Binding TargetColumns, StringFormat={}{0}}" />
        </StackPanel>

        <StackPanel Margin="0,12,0,0">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SizingMode}" Value="Rows">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <Label Margin="0,0,0,4" Content="Target rows (vertical tiles)" />
            <Slider Minimum="1"
                    Maximum="10"
                    Value="{Binding TargetRows, Mode=TwoWay}"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{DynamicResource TextBrush}"
                       Text="{Binding TargetRows, StringFormat={}{0}}" />
        </StackPanel>

        <Label Margin="0,16,0,4" Content="Viewport adjust (pixels)" />
        <Slider Minimum="-200"
                Maximum="200"
                Value="{Binding ViewportAdjustPx, Mode=TwoWay}"
                TickFrequency="1"
                IsSnapToTickEnabled="True" />
        <TextBlock Margin="0,4,0,0"
                   Foreground="{DynamicResource TextBrush}"
                   Text="{Binding ViewportAdjustPx, StringFormat={}{0} px}" />
        <TextBlock Margin="0,20,0,0"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextBrush}"
                   Text="When you resize the Playnite window, grid cover width adjusts automatically. Column mode keeps about this many tiles across the library area. Row mode keeps about this many visible rows; column count will vary. Use viewport adjust if a theme still leaves side gutters. If a Playnite update stops this from working, open an issue with your Playnite version." />
    </StackPanel>
</UserControl>
